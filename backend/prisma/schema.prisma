generator client {
    provider   = "prisma-client-js"
    engineType = "library"
}

datasource db {
    provider = "postgresql"
}

enum GenresStatus {
    PENDING
    OK
    NONE
    ERROR
}

enum TitleMetaStatus {
    PENDING
    OK
    ERROR
}

enum GlobalRowStatus {
    OK
    ERROR
    RATE_LIMITED
}

model GlobalRowCache {
    id       String @id @default(cuid())
    key      String @unique // ex: "popular:NETFLIX:all", "popular:NETFLIX:tv", "popular:NETFLIX:movie"
    provider String
    kind     String // popular | new (optional later)
    mode     String // all | tv | movie
    region   String @default("US")

    itemsJson String // JSON string: array of RowItem objects
    status    GlobalRowStatus @default(OK)

    fetchedAt DateTime @default(now())
    expiresAt DateTime

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([provider, kind, mode])
    @@index([expiresAt])
}

model User {
    id           String         @id @default(cuid())
    email        String         @unique
    passwordHash String
    providers    UserProvider[]
    savedItems   SavedItem[]
    createdAt    DateTime       @default(now())
    updatedAt    DateTime       @updatedAt
}

model UserProvider {
    id       String @id @default(cuid())
    userId   String
    provider String

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([userId, provider])
}

model SavedItem {
    id               String   @id @default(cuid())
    userId           String
    provider         String
    watchmodeTitleId Int
    title            String
    type             String
    poster           String?
    watchUrl         String?
    createdAt        DateTime @default(now())

    genres            String[]     @default([])
    genresStatus      GenresStatus @default(PENDING)
    genresAttemptedAt DateTime?

    user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
    titleMeta Title @relation(fields: [watchmodeTitleId], references: [watchmodeTitleId])

    @@unique([userId, provider, watchmodeTitleId])
}

model Title {
    // Shared/global key
    watchmodeTitleId Int @id

    // Core identity
    title  String
    type   String
    poster String?

    // Extra metadata for the modal (optional, filled by ensureMetadata)
    year           Int?
    runtimeMinutes Int?
    seasons        Int?
    description    String?

    // Metadata bookkeeping
    metaStatus    TitleMetaStatus @default(PENDING)
    lastFetchedAt DateTime?
    createdAt     DateTime        @default(now())
    updatedAt     DateTime        @updatedAt

    // Relation back to user items (optional but useful)
    savedItems SavedItem[]

    @@index([metaStatus])
    @@index([lastFetchedAt])
}

model LandingTitle {
    id        Int      @id @default(autoincrement())
    title     String
    posterUrl String
    provider  String? // "NETFLIX", "HULU", etc (optional label)
    type      String? // "movie" | "tv" (optional)
    createdAt DateTime @default(now())

    @@index([createdAt])
}

model CacheEntry {
    key       String   @id
    valueJson String
    expiresAt DateTime
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([expiresAt])
}
